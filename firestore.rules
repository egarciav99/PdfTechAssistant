rules_version = '2';

// Firestore Security Rules for PDF Technical Assistant
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Allow read/write to the main user doc only for the owner
      allow read: if isAuthenticated() && isOwner(userId);
      // Allow create with empty doc or limited fields
      allow create: if isAuthenticated() && isOwner(userId);
      // Allow update only with known fields
      allow update: if isAuthenticated() && isOwner(userId);
      
      // Documents subcollection — enforce schema on create
      match /documents/{documentId} {
        allow read: if isAuthenticated() && isOwner(userId);
        
        // Only allow creating documents with the required schema
        allow create: if isAuthenticated() && isOwner(userId)
          && request.resource.data.keys().hasAll(['nombreDocumento', 'storageId', 'createdAt'])
          && request.resource.data.nombreDocumento is string
          && request.resource.data.storageId is string
          && request.resource.data.createdAt is number
          && request.resource.data.storageId.matches('^' + request.auth.uid + '_.*');
        
        // Allow delete for own documents
        allow delete: if isAuthenticated() && isOwner(userId);
        
        // Disallow arbitrary updates to documents (they are immutable after creation)
        allow update: if false;
      }
    }
    
    // Resumenes collection - summaries generated by Cloud Functions
    // Users can read their own summaries (storageId contains their UID)
    match /resumenes/{storageId} {
      // Allow read if authenticated and the storageId starts with user's UID
      allow read: if isAuthenticated() && 
                     storageId.matches('^' + request.auth.uid + '_.*');
      
      // Only Cloud Functions can write (no auth context)
      allow write: if false;
    }
    
    // Embedding cache collection (used by Cloud Functions)
    match /embeddingCache/{cacheId} {
      // Only allow Cloud Functions to read/write (no user access)
      allow read, write: if false;
    }
    
    // Search cache collection (used by Cloud Functions)
    match /searchCache/{cacheId} {
      // Only allow Cloud Functions to read/write (no user access)
      allow read, write: if false;
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
