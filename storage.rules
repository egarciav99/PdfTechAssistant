rules_version = '2';

// Firebase Storage Security Rules for PDF Technical Assistant
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to extract UID from filename (format: UID_filename.ext)
    function getFileOwnerUid(filename) {
      // Split by underscore and get first part (the UID)
      return filename.split('_')[0];
    }
    
    // Files are stored in root with format: {userId}_{filename}.pdf
    match /{filename} {
      // Allow read if authenticated and the filename starts with user's UID
      allow read: if isAuthenticated() && 
                     getFileOwnerUid(filename) == request.auth.uid;
      
      // Allow write (upload) if authenticated, filename matches UID,
      // file is a PDF, and file size is under 50MB
      allow write: if isAuthenticated() && 
                      getFileOwnerUid(filename) == request.auth.uid &&
                      request.resource.size < 50 * 1024 * 1024 &&
                      request.resource.contentType == 'application/pdf';
      
      // Allow delete if authenticated and the filename starts with user's UID
      allow delete: if isAuthenticated() && 
                       getFileOwnerUid(filename) == request.auth.uid;
    }
  }
}
